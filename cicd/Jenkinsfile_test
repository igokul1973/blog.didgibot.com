// Jenkins CI/CD for Angular frontend (Node 22 agent pod + kaniko)
// Stages align with cicd/Dockerfile.production (lint, test, build) and final image build via kaniko.
// Two-run behavior: first run bumps version and exits; second run (post-push) executes lint/test/build/image stages.

pipeline {
    agent {
        kubernetes {
            yamlFile 'cicd/node-git-chromium-pod.yaml'
        }
    }
    environment {
        RESULTS_FILE_NAME = 'job-results.txt'
        IMAGE_TAG_NUMBER = "${BUILD_NUMBER}"
        DOCKER_IMAGE_NAME = "igk19/blog:${BUILD_NUMBER}"
        SHOULD_BUMP_VERSION = 'false'
    }
    options { timestamps() }

    stages {
        stage('Prepare') {
            steps {
                script { check() }
                container('node-git-chromium') {
                    sh '''
                        cd /workspace
                        pnpm install --frozen-lockfile
                    '''
                }
            }
        }

        stage('Bump version') {
            when { environment name: 'SHOULD_BUMP_VERSION', value: 'true' }
            steps {
                container('node-git-chromium') {
                    withCredentials([
                        sshUserPrivateKey(credentialsId: 'github_ssh_credentials', keyFileVariable: 'SSH_KEY'),
                        usernamePassword(credentialsId: 'bc934908-4192-4b50-bb32-5fad86943329', usernameVariable: 'USERNAME', passwordVariable: 'GH_TOKEN')
                    ]) {
                        script {
                            sh """
                                git config --global --add safe.directory ${env.WORKSPACE}
                                git checkout ${env.BRANCH_NAME}
                                pnpm version --no-git-tag-version patch
                                git add --all
                            """
                            def newAppVersion = readJSON text: sh(returnStdout: true, script: 'pnpm version --json')
                            env.NEW_APP_VERSION = newAppVersion['blog.didgibot.com']
                            def commitMessage = "Upgrade to new application version - ${env.NEW_APP_VERSION} - [version bump]"
                            def encodedPassword = URLEncoder.encode("$GH_TOKEN", 'UTF-8')
                            sh "git commit -m '${commitMessage}'"
                            sh "git push https://${USERNAME}:${encodedPassword}@github.com/${USERNAME}/blog.didgibot.com.git"
                        }
                    }
                }
            }
        }

        stage('Lint (Dockerfile.production:lint)') {
            when { environment name: 'SHOULD_BUMP_VERSION', value: 'false' }
            steps {
                container('kaniko') {
                    sh '''
                        cd /workspace
                        /kaniko/executor --dockerfile `pwd`/cicd/Dockerfile.production \
                            --context `pwd` \
                            --target=lint \
                            --no-push
                    '''
                }
            }
        }

        stage('Test (Dockerfile.production:test)') {
            when { environment name: 'SHOULD_BUMP_VERSION', value: 'false' }
            steps {
                container('kaniko') {
                    sh '''
                        cd /workspace
                        /kaniko/executor --dockerfile `pwd`/cicd/Dockerfile.production \
                            --context `pwd` \
                            --target=test \
                            --no-push
                    '''
                }
            }
        }

        stage('Publish Coverage Artifact') {
            when { environment name: 'SHOULD_BUMP_VERSION', value: 'false' }
            steps {
                archiveArtifacts artifacts: 'coverage/**/*', allowEmptyArchive: false
            }
        }

        stage('Build (Dockerfile.production:build)') {
            when { environment name: 'SHOULD_BUMP_VERSION', value: 'false' }
            steps {
                container('kaniko') {
                    sh '''
                        cd /workspace
                        /kaniko/executor --dockerfile `pwd`/cicd/Dockerfile.production \
                            --context `pwd` \
                            --target=build \
                            --no-push
                    '''
                }
                // Build dist locally for app image input
                container('node-git-chromium') {
                    sh '''
                        cd /workspace
                        pnpm build
                    '''
                }
            }
        }

        stage('Image Build & Push (kaniko)') {
            when { environment name: 'SHOULD_BUMP_VERSION', value: 'false' }
            steps {
                container('kaniko') {
                    sh """
                        cd /workspace
                        /kaniko/executor --dockerfile `pwd`/cicd/Dockerfile \
                            --context `pwd`/cicd \
                            --destination=${DOCKER_IMAGE_NAME}
                    """
                }
                script {
                    env.BUILD_RESULT = "Built and pushed ${DOCKER_IMAGE_NAME}"
                }
            }
        }

        stage('Change image in blog.didgibot.com deployment') {
            when { environment name: 'SHOULD_BUMP_VERSION', value: 'false' }
            steps {
                build job: 'change-image-name-in-blog-didgibot-com/' + env.BRANCH_NAME, parameters: [
                    string(name: 'IMAGE_TAG_NUMBER', value: env.IMAGE_TAG_NUMBER)
                ]
            }
        }
    }

    post {
        always {
            postProcess()
        }
    }
}

void check() {
    env.BUILD_RESULT = 'ABORTED'
    env.SHOULD_BUMP_VERSION = 'false'
    def result = sh(script: "git log -1 | grep '.*\\[version bump\\].*'", returnStatus: true)
    if (result != 0) {
        env.SHOULD_BUMP_VERSION = 'true'
    }
}

void postProcess() {
    if (env.SHOULD_BUMP_VERSION == 'true') {
        if (env.NEW_APP_VERSION) {
            env.BUILD_RESULT = "Bumped application version to ${env.NEW_APP_VERSION}"
        } else {
            env.BUILD_RESULT = "Version bump attempted; NEW_APP_VERSION unavailable"
        }
    } else if (!env.BUILD_RESULT) {
        env.BUILD_RESULT = "Pipeline completed (no version bump)"
    }
    writeFile file: env.RESULTS_FILE_NAME, text: "The job build result: ${env.BUILD_RESULT}"
    archiveArtifacts env.RESULTS_FILE_NAME
}