{
    "mcpServers": {
        "playwright": {
            "command": "npx",
            "args": [
                "@playwright/mcp@latest",
                "--cdp-endpoint",
                "ws://host.docker.internal:9250/devtools/browser/80eb765d-4fb8-4435-ad91-107f4e21314b"
            ]
        },
        "angular-cli": {
            "command": "npx",
            "args": [
                "-y",
                "@angular/cli",
                "mcp"
            ]
        },
        "ngm-dev-blocks": {
            "command": "npx",
            "args": [
                "-y",
                "@ngm-dev/cli",
                "mcp",
                "/workspaces/blog.didgibot.com"
            ]
        }
    }
}