{
    "mcpServers": {
        "playwright": {
            "command": "npx",
            "args": [
                "@playwright/mcp@latest",
                "--cdp-endpoint",
                "ws://host.docker.internal:9250/devtools/browser/aaeb60d3-44f7-459b-852a-026c94288d88"
            ]
        },
        "angular-cli": {
            "command": "npx",
            "args": [
                "-y",
                "@angular/cli",
                "mcp"
            ]
        },
        "ngm-dev-blocks": {
            "command": "npx",
            "args": [
                "-y",
                "@ngm-dev/cli",
                "mcp",
                "/workspaces/blog.didgibot.com"
            ]
        }
    }
}