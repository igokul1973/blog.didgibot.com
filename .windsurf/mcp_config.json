{
    "mcpServers": {
        "playwright": {
            "command": "npx",
            "args": [
                "@playwright/mcp@latest",
                "--cdp-endpoint",
                "ws://host.docker.internal:9250/devtools/browser/74304979-93b2-4c7a-a198-ad5118260dfc"
            ]
        },
        "angular-cli": {
            "command": "npx",
            "args": [
                "-y",
                "@angular/cli",
                "mcp"
            ]
        },
        "ngm-dev-blocks": {
            "command": "npx",
            "args": [
                "-y",
                "@ngm-dev/cli",
                "mcp",
                "/workspaces/blog.didgibot.com"
            ]
        }
    }
}