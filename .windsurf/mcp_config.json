{
    "mcpServers": {
        "playwright": {
            "command": "npx",
            "args": [
                "@playwright/mcp@latest",
                "--cdp-endpoint",
                "ws://host.docker.internal:9250/devtools/browser/503684bc-ddd5-4373-9880-45e87c0c69b8"
            ]
        },
        "angular-cli": {
            "command": "npx",
            "args": [
                "-y",
                "@angular/cli",
                "mcp"
            ]
        },
        "ngm-dev-blocks": {
            "command": "npx",
            "args": [
                "-y",
                "@ngm-dev/cli",
                "mcp",
                "/workspaces/blog.didgibot.com"
            ]
        }
    }
}